<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude known false positives and legacy code patterns -->

    <!-- Exclude generated code -->
    <Match>
        <Package name="org.jbrain.qlink.cmd.action"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- Exclude legacy serialization patterns -->
    <Match>
        <Class name="~.*\.cmd\.action\..*"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- Exclude test code -->
    <Match>
        <Package name="~.*\.test\..*"/>
    </Match>

    <!-- Exclude main method in server class -->
    <Match>
        <Class name="org.jbrain.qlink.QLinkServer"/>
        <Method name="main"/>
        <Bug pattern="DM_EXIT"/>
    </Match>

    <!-- Exclude deprecated methods that we're maintaining for compatibility -->
    <Match>
        <Bug pattern="DE_MIGHT_IGNORE"/>
    </Match>

    <!-- Exclude specific patterns that are acceptable for this legacy project -->
    <Match>
        <Bug pattern="MS_SHOULD_BE_FINAL"/>
    </Match>

    <!-- Exclude SQL-related warnings for now (will be addressed in Phase 2) -->
    <Match>
        <Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
    </Match>

</FindBugsFilter>